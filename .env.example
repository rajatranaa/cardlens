# CardLens environment variables — NAMES ONLY. Never commit real values.
# Copy to .env and fill in locally / set in Railway/Render env settings.

# --- Database (PostgreSQL) ---
DATABASE_URL=jdbc:postgresql://localhost:5432/cardlens
DB_USER=
DB_PASSWORD=

# --- Static API key guarding /api/** (shared by backend + MCP server) ---
CARDLENS_API_KEY=

# NOTE: no LLM API key needed. Extraction is done by the Claude app itself:
# the backend returns each statement as Markdown via the MCP `fetch_statements`
# tool, Claude extracts the fields, then calls the `save_statement` tool.

# --- PDF -> Markdown (markitdown, Python) ---
# Requires Python 3.10+ with: pip install -r backend/scripts/requirements.txt
# Set MARKDOWN_PYTHON only if the plain `python` command isn't the real interpreter.
MARKDOWN_PYTHON=python

# --- Gmail OAuth (scope: gmail.readonly only) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Per-card PDF password env vars ---
# One per card. The NAME here is what you store in cards.password_template_key.
# The value is the already-built statement password (e.g. NAME+DDMM). Never in DB/repo.
CARD_HDFC_DINERS_PWD=
CARD_ICICI_AMAZON_PWD=
CARD_SBI_CASHBACK_PWD=
CARD_AXIS_MAGNUS_PWD=
CARD_AMEX_PLATINUM_PWD=

# --- MCP server ---
BACKEND_URL=http://localhost:8080
MCP_PORT=3000
